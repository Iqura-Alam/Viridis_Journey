<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.HowToPlayController"
      alignment="CENTER"
      spacing="30"
      style="-fx-background-color: #1abc9c; -fx-padding: 50; -fx-background-image: url('/img/VIRIDIS_JOURNEY.png'); -fx-background-size: cover; -fx-background-position: center;">

    <!-- Load custom font -->
    <fx:define>
        <Font fx:id="karmaticFont" name="Karmatic Arcade" size="36"/>
    </fx:define>

    <!-- Screen Title -->
    <Label text="HOW TO PLAY" font="$karmaticFont"
           style="-fx-text-fill: white; -fx-effect: dropshadow(gaussian, black, 4, 0, 2, 2);"/>

    <!-- Instructions -->
    <Label text="Objective: Place energy sources to meet the city's daily energy demand while managing pollution and budget."
           wrapText="true" maxWidth="600"
           style="-fx-font-family: 'Karmatic Arcade'; -fx-font-size: 18px; -fx-text-fill: white; -fx-text-alignment: center;"/>

    <!-- Back Button -->
    <Button fx:id="backButton" text="Back" onAction="#goToHome"
            style="-fx-font-family: 'Karmatic Arcade'; -fx-font-size: 24; -fx-background-color: #e74c3c; -fx-text-fill: white; -fx-padding: 10 30 10 30;"/>

</VBox>
